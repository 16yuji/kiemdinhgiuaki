<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" action="http://127.0.0.1:8000/admin/settlements" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Từ khóa</label>
                <input
                    type="text"
                    name="keyword"
                    class="form-control"
                    value=""
                    placeholder="Mã đơn, khách sạn, tên/email Owner"
                >
            </div>

            <div class="col-md-4">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="temporary_recorded" >
                        Ghi nhận tạm
                    </option>
                    <option value="waiting_settlement" >
                        Chờ đối soát
                    </option>
                    <option value="settled" >
                        Đã đối soát
                    </option>
                    <option value="adjusted" >
                        Đã điều chỉnh
                    </option>
                    <option value="postponed" >
                        Tạm hoãn
                    </option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end gap-2">
                <button class="btn btn-primary w-100">Lọc</button>
                <a href="http://127.0.0.1:8000/admin/settlements" class="btn btn-outline-secondary">
                    Xóa
                </a>
            </div>
        </form>
    </div>
